generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model categories {
  id    Int     @id @default(autoincrement())
  name  String
  slug  String  @unique
  order Int     @default(0)
  links links[]
}

model links {
  id         Int         @id @default(autoincrement())
  title      String
  url        String
  categoryId Int?
  categories categories? @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String
  subscribedAt DateTime @default(now())
}

model News {
  id          Int    @id @default(autoincrement())
  title       String
  summary     String
  imageUrl    String
  publishedAt String
  status      String @default("draft")
}

model Message {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  message    String
  receivedAt DateTime @default(now())
  isRead     Boolean  @default(false)
}

model Page {
  id          Int     @id @default(autoincrement())
  menuTitle   String
  menuTitleEn String?
  slug        String  @unique
  category    String
  content     String
  status      String  @default("draft")
  updatedAt   String
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Job {
  id               Int    @id @default(autoincrement())
  title            String
  department       String
  location         String
  type             String
  description      String
  requirements     String
  responsibilities String
  status           String @default("active")
  createdAt        String
}

model Application {
  id          Int    @id @default(autoincrement())
  jobId       Int
  fullName    String
  email       String
  phone       String
  linkedinUrl String
  cvUrl       String
  coverLetter String
  status      String @default("new")
  appliedAt   String
}
